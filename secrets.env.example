# Copy to secrets.env (gitignored) and set your group's shared co-op password.
COOP_PASSWORD=change-me-to-a-long-random-string

# Optional: a Nexus Mods Premium API key. With it, `erm fetch`/`erm update`
# auto-download nexus-sourced mods instead of printing a manual-download
# link. Free-account keys can list files but get HTTP 403 from the download
# endpoint, so leave this blank if you're not Premium.
NEXUS_API_KEY=
